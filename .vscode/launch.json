{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: API (uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/axon-src",
      "args": [
        "src.api.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8080",
        "--reload"
      ],
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "Python: MCP Server",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/axon-src/src/mcp_server/main.py",
      "cwd": "${workspaceFolder}/axon-src",
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}
